-- Draggable Window
local dragging = false
local dragInput
local dragStart
local startPos

local function updateDrag(input)
	local delta = input.Position - dragStart

	frame.Position = UDim2.new(
		startPos.X.Scale,
		startPos.X.Offset + delta.X,
		startPos.Y.Scale,
		startPos.Y.Offset + delta.Y
	)
end

titleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = frame.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

titleBar.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input == dragInput then
		updateDrag(input)
	end
end)

local function getRemotes()
	local remotes = {}

	for _, obj in ipairs(game:GetDescendants()) do
		if obj:IsA("RemoteEvent")
			or obj:IsA("RemoteFunction")
			or obj:IsA("UnreliableRemoteEvent") then

			table.insert(remotes, obj)
		end
	end

	table.sort(remotes, function(a, b)
		return a:GetFullName() < b:GetFullName()
	end)

	return remotes
end

local function refreshList(filter)
	for _, child in ipairs(scrollingFrame:GetChildren()) do
		if child:IsA("TextButton") then
			child:Destroy()
		end
	end

	local count = 0

	for _, remote in ipairs(getRemotes()) do
		local fullName = remote:GetFullName()

		if filter == "" or string.find(
			string.lower(fullName),
			string.lower(filter),
			1,
			true
		) then

			local button = Instance.new("TextButton")
			button.Size = UDim2.new(1, -5, 0, 25)
			button.Text = remote.Name .. " (" .. remote.ClassName .. ")"
			button.TextSize = 12
			button.Parent = scrollingFrame

			button.MouseButton1Click:Connect(function()
				selectedRemote = remote
				nameLabel.Text = remote.Name

				local path = "game." .. remote:GetFullName()

				if remote:IsA("RemoteFunction") then
					path ..= ":InvokeServer()"
				elseif remote:IsA("RemoteEvent") then
					path ..= ":FireServer()"
				elseif remote:IsA("UnreliableRemoteEvent") then
					path ..= ":FireServer()"
				end

				pathBox.Text = path
			end)

			count += 1
		end
	end

	scrollingFrame.CanvasSize = UDim2.new(0, 0, 0, count * 28)
end

-- Toggle Explorer
toggleButton.MouseButton1Click:Connect(function()
	enabled = not enabled

	searchBox.Visible = enabled
	scrollingFrame.Visible = enabled
	detailsFrame.Visible = enabled

	toggleButton.Text = enabled and "ON" or "OFF"
end)

refreshButton.MouseButton1Click:Connect(function()
	refreshList(searchBox.Text)
end)

searchBox:GetPropertyChangedSignal("Text"):Connect(function()
	refreshList(searchBox.Text)
end)

copyButton.MouseButton1Click:Connect(function()
	if selectedRemote then
		pathBox:CaptureFocus()
		pathBox.SelectionStart = 1
		pathBox.CursorPosition = #pathBox.Text + 1
	end
end)

game.DescendantAdded:Connect(function(obj)
	if obj:IsA("RemoteEvent")
		or obj:IsA("RemoteFunction")
		or obj:IsA("UnreliableRemoteEvent") then

		refreshList(searchBox.Text)
	end
end)

game.DescendantRemoving:Connect(function(obj)
	if obj:IsA("RemoteEvent")
		or obj:IsA("RemoteFunction")
		or obj:IsA("UnreliableRemoteEvent") then

		refreshList(searchBox.Text)
	end
end)

refreshList("")
