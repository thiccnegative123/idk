local function hideMenu()
	currentCategory = nil
	frame.Visible = false
end

local function startTimeout()

	timeoutId += 1
	local currentId = timeoutId

	task.delay(TIMEOUT, function()

		if currentId ~= timeoutId then
			return
		end

		hideMenu()
	end)
end

local function showMain()

	currentCategory = nil
	frame.Visible = true

	title.Text = "QUICK CHAT"
	categoryLabel.Text = ""

	labels[1].Text = "1  POST GAME"
	labels[2].Text = "2  COMPLIMENTS"
	labels[3].Text = "3  REACTIONS"
	labels[4].Text = "4  APOLOGIES"

	startTimeout()
end

local function showCategory(index)

	currentCategory = index
	frame.Visible = true

	local category = categories[index]

	title.Text = "QUICK CHAT"
	categoryLabel.Text = category.name

	for i = 1,4 do
		labels[i].Text = i .. "  " .. category.messages[i]
	end

	startTimeout()
end

local keyMap = {
	[Enum.KeyCode.One] = 1,
	[Enum.KeyCode.Two] = 2,
	[Enum.KeyCode.Three] = 3,
	[Enum.KeyCode.Four] = 4
}

UIS.InputBegan:Connect(function(input, processed)

	if processed then
		return
	end

	-- TOGGLE QUICK CHAT
	if input.KeyCode == Enum.KeyCode.T then

		quickChatEnabled = not quickChatEnabled

		if not quickChatEnabled then
			hideMenu()
		end

		return
	end

	-- DISABLED
	if not quickChatEnabled then
		return
	end

	local number = keyMap[input.KeyCode]

	if not number then
		return
	end

	-- OPEN CATEGORY
	if not frame.Visible then
		showCategory(number)
		return
	end

	-- SEND MESSAGE
	local message = categories[currentCategory].messages[number]

	if message then

		local channel = TextChatService.TextChannels:FindFirstChild("RBXGeneral")

		if channel then
			channel:SendAsync(message)
		end
	end

	hideMenu()
end)
