-- ================= FIND PLAYER =================
local function findPlayer(input)
	input = string.lower(input)
	if input == "" then return nil end

	for _, p in ipairs(Players:GetPlayers()) do
		if string.find(string.lower(p.Name), input, 1, true)
			or string.find(string.lower(p.DisplayName), input, 1, true) then
			return p
		end
	end
end


-- ================= STATE =================
local target = nil
local orbiting = false
local savedCFrame = nil


-- live update selection
box:GetPropertyChangedSignal("Text"):Connect(function()
	target = findPlayer(box.Text)

	if target then
		label.Text = "Selected: " .. target.Name
	else
		label.Text = "Selected: none"
	end
end)


-- ================= ENTER FIX (IMPORTANT) =================
-- THIS is the correct way (works 100%)
box.FocusLost:Connect(function(enterPressed)
	if enterPressed then
		gui.Enabled = false
	end
end)


-- clear when focused
box.Focused:Connect(function()
	box.Text = ""
end)


-- ================= INPUT =================
UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.UserInputType ~= Enum.UserInputType.Keyboard then return end

	-- toggle GUI
	if input.KeyCode == Enum.KeyCode.B then
		gui.Enabled = not gui.Enabled

		if gui.Enabled then
			task.wait()
			box:CaptureFocus()
		else
			box:ReleaseFocus()
		end
	end

	-- toggle orbit
	if input.KeyCode == Enum.KeyCode.Z then
		if target and target.Character then
			local hrp = target.Character:FindFirstChild("HumanoidRootPart")

			if hrp then
				if not orbiting then
					savedCFrame = hrp.CFrame
					orbiting = true
				else
					orbiting = false
					if savedCFrame then
						hrp.CFrame = savedCFrame
					end
				end
			end
		end
	end
end)


-- ================= ORBIT SYSTEM =================
RunService.RenderStepped:Connect(function()
	if not orbiting then return end

	local char = player.Character
	local targetChar = target and target.Character

	if not char or not targetChar then return end

	local hrp = char:FindFirstChild("HumanoidRootPart")
	local thrp = targetChar:FindFirstChild("HumanoidRootPart")

	if not hrp or not thrp then return end

	local t = os.clock()

	local radius = 10
	local speed = 30

	local offset = Vector3.new(
		math.cos(t * speed) * radius,
		2,
		math.sin(t * speed) * radius
	)

	thrp.CFrame = hrp.CFrame * CFrame.new(offset)
end)
